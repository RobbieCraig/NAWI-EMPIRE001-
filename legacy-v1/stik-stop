<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NAWI-EMPIRE | Sticker Designs</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root { --gold: #D4AF37; --dark: #111; --black: #000; }
        body { background: var(--black); color: #fff; font-family: 'Inter', sans-serif; padding: 20px 20px 120px; text-align: center; margin: 0; }
        
        /* HEADER */
        .header { margin-top: 20px; margin-bottom: 30px; }
        .header h1 { color: var(--gold); margin: 0; letter-spacing: 2px; font-size: 24px; font-weight: 900; text-transform: uppercase; }
        .header p { color: #888; font-size: 13px; margin-top: 5px; }

        /* STICKER GRID */
        .gallery-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 20px; }
        .sticker-item { 
            background: #111; 
            border: 1px solid #222; 
            border-radius: 50%; /* Circular look for stickers */
            aspect-ratio: 1 / 1; 
            display: flex; 
            align-items: center; 
            justify-content: center;
            overflow: hidden;
            position: relative;
            transition: 0.3s;
        }
        .sticker-item:hover { border-color: var(--gold); transform: scale(1.05); }
        .sticker-item img { width: 80%; height: 80%; object-fit: contain; }
        .placeholder-text { font-size: 9px; color: #444; text-transform: uppercase; }

        /* CTA SECTION */
        .cta-box { background: rgba(212, 175, 55, 0.05); border: 1px solid var(--gold); padding: 25px; border-radius: 15px; margin-top: 30px; }
        .cta-box p { font-size: 14px; margin-bottom: 15px; color: #ccc; }
        .order-btn { 
            display: block;
            background: var(--gold); 
            color: #000; 
            padding: 15px; 
            text-decoration: none; 
            border-radius: 10px; 
            font-weight: 800; 
            font-size: 14px;
        }

        /* MASTER NAVIGATION */
        .master-nav { position: fixed; bottom: 0; left: 0; width: 100%; background: #080808; border-top: 1px solid #111; display: flex; justify-content: space-around; padding: 15px 0; z-index: 1000; }
        .nav-box { text-align: center; cursor: pointer; color: #555; text-decoration: none; }
        .nav-box p { font-size: 10px; margin: 5px 0 0; font-weight: bold; }
        .active-tab { color: var(--gold) !important; }
        .plus-btn { background: var(--gold); width: 45px; height: 45px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-top: -10px; }
    </style>
</head>
<body>

    <div class="header">
        <h1>✨ Custom Stickers</h1>
        <p>Premium Die-Cut & Digital Assets</p>
    </div>

    <div class="gallery-grid">
        <div class="sticker-item"><span class="placeholder-text">Circular Logo</span></div>
        <div class="sticker-item" style="border-radius: 15px;"><span class="placeholder-text">Square Badge</span></div>
        <div class="sticker-item" style="border-radius: 15px;"><span class="placeholder-text">Brand Icon</span></div>
        <div class="sticker-item"><span class="placeholder-text">Gold Seal</span></div>
    </div>

    <div class="cta-box">
        <p>Get high-quality stickers for your brand.</p>
        <a href="inbox.html" class="order-btn">ORDER STICKERS</a>
    </div>

    <nav class="master-nav">
        <a href="index.html" class="nav-box"><i class="fa-solid fa-house" style="font-size: 20px;"></i><p>Home</p></a>
        <a href="discover.html" class="nav-box"><i class="fa-solid fa-compass" style="font-size: 20px;"></i><p>Discover</p></a>
        <div onclick="window.location.href='app-grid.html'" class="nav-box">
            <div class="plus-btn"><i class="fa-solid fa-plus" style="font-size: 20px; color: black;"></i></div>
        </div>
        <a href="inbox.html" class="nav-box"><i class="fa-solid fa-message" style="font-size: 20px;"></i><p>Inbox</p></a>
        <a href="profile.html" class="nav-box"><i class="fa-solid fa-user" style="font-size: 20px;"></i><p>Profile</p></a>
    </nav>

</body>
</html>
