<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>ESTABLISH NODE | NAWI EMPIRE</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;700;900&display=swap" rel="stylesheet">
    <style>
        :root { --gold: #D4AF37; --black: #050505; --dark: #0a0a0a; }
        body { margin: 0; background: var(--black); color: white; font-family: 'Inter', sans-serif; min-height: 100vh; display: flex; align-items: center; justify-content: center; padding: 20px; box-sizing: border-box; }
        
        .reg-container { width: 100%; max-width: 400px; text-align: center; animation: fadeIn 0.8s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        .logo-area { margin-bottom: 30px; }
        .logo-icon { font-size: 50px; color: var(--gold); margin-bottom: 15px; text-shadow: 0 0 20px rgba(212,175,55,0.3); }
        .logo-area h1 { font-size: 22px; letter-spacing: 5px; text-transform: uppercase; margin: 0; font-weight: 900; color: var(--gold); }
        .logo-area p { font-size: 10px; color: #555; text-transform: uppercase; margin-top: 10px; letter-spacing: 2px; }

        .form-card { background: var(--dark); padding: 30px; border-radius: 25px; border: 1px solid #1a1a1a; text-align: left; }
        
        .input-group { margin-bottom: 20px; }
        .input-group label { font-size: 9px; color: var(--gold); text-transform: uppercase; font-weight: 800; display: block; margin-bottom: 8px; letter-spacing: 1px; }
        
        input { width: 100%; background: #000; border: 1px solid #222; padding: 15px; border-radius: 12px; color: white; box-sizing: border-box; font-size: 14px; outline: none; transition: 0.3s; }
        input:focus { border-color: var(--gold); background: #080808; }

        .check-group { display: flex; gap: 12px; align-items: flex-start; margin-bottom: 25px; }
        .check-group input { width: auto; margin-top: 3px; accent-color: var(--gold); cursor: pointer; }
        .check-group p { font-size: 11px; color: #666; margin: 0; line-height: 1.5; }

        .btn-register { width: 100%; background: var(--gold); color: #000; padding: 18px; border-radius: 15px; border: none; font-weight: 900; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; transition: 0.3s; font-size: 12px; }
        .btn-register:active { transform: scale(0.98); }

        .footer-link { margin-top: 25px; font-size: 11px; color: #444; }
        .footer-link a { color: var(--gold); text-decoration: none; font-weight: 900; }
    </style>
</head>
<body>

    <div class="reg-container">
        <div class="logo-area">
            <div class="logo-icon"><i class="fa-solid fa-crown"></i></div>
            <h1>NAWI-EMPIRE</h1>
            <p>Founder Onboarding Protocol</p>
        </div>

        <div class="form-card">
            <div class="input-group">
                <label>Sovereign Full Name</label>
                <input type="text" id="fullname" placeholder="Enter your legal name" required>
            </div>

            <div class="input-group">
                <label>Empire Email</label>
                <input type="email" id="email" placeholder="citizen@nawi-empire.com" required>
            </div>

            <div class="input-group">
                <label>Security Password</label>
                <input type="password" id="password" placeholder="••••••••" required>
            </div>

            <div class="check-group">
                <input type="checkbox" id="terms" required>
                <p>I agree to follow the platform rules and respect the authority of the 7 Pillars.</p>
            </div>

            <button class="btn-register" onclick="handleRegistration()">Activate My Status</button>
        </div>
        
        <p class="footer-link">Already a Founder? <a href="login.html">Login here</a></p>
    </div>

    <script src="nav.js"></script> 
    <script>
        const API_URL = "https://nawi-empire1.onrender.com";

        async function handleRegistration() {
            const name = document.getElementById('fullname').value;
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;
            const terms = document.getElementById('terms').checked;

            if(!name || !email || !password) {
                showEmpireAlert("All identification fields required", "warning");
                return;
            }

            if(!terms) {
                showEmpireAlert("You must accept the Imperial Rules", "warning");
                return;
            }

            // 🛡️ CAPTURE DEVICE IDENTITY (Prevents Multiple Accounts)
            const deviceId = btoa(navigator.userAgent + screen.width + screen.height);

            try {
                const response = await fetch(`${API_URL}/api/register`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        fullName: name, 
                        email: email, 
                        password: password, 
                        deviceId: deviceId 
                    })
                });

                const data = await response.json();

                if (data.success) {
                    showEmpireAlert("✨ Node Created. Welcome to the Empire.");
                    setTimeout(() => { window.location.href = "login.html"; }, 2000);
                } else {
                    // Triggers if device is already registered or other server error
                    showEmpireAlert(data.message, "warning");
                }
            } catch (err) {
                showEmpireAlert("Vault Sync Error. Try again.", "warning");
            }
        }
    </script>
</body>
</html>
